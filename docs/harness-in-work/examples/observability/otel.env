# OpenTelemetry 텔레메트리 설정 예시
# 셸 프로파일이나 실행 환경에 export 한다. 값은 사내 인프라에 맞게 바꾼다.
#
# 목적: 세션 수·토큰 사용량·도구 호출 빈도 같은 지표를 사내 모니터링
#       인프라(Grafana / Datadog / OTLP 수집기)로 내보낸다.

# 텔레메트리 활성화
export CLAUDE_CODE_ENABLE_TELEMETRY=1

# 메트릭 익스포터: OTLP
export OTEL_METRICS_EXPORTER=otlp
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.internal:4317

# (선택) 로그도 내보내려면
# export OTEL_LOGS_EXPORTER=otlp

# 집계를 쉽게 하려고 팀·환경 태그를 붙인다
export OTEL_RESOURCE_ATTRIBUTES="team=marketflow,env=prod"

# 내보내기 주기(밀리초). 너무 짧으면 부하, 너무 길면 지연.
export OTEL_METRIC_EXPORT_INTERVAL=60000

# 주의: 트랜스크립트/로그에는 민감정보가 포함될 수 있다.
#       수집기 접근 권한과 보존 기간을 반드시 정한다.
